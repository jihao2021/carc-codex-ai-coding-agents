#!/usr/bin/env bash
set -euo pipefail

REAL_CODEX="${CARC_CODEX_REAL:-codex}"

unsafe_config_override() {
  case "$1" in
    *sandbox_workspace_write.network_access*=*true*|\
    *features.browser_use*=*true*|\
    *features.computer_use*=*true*|\
    *features.in_app_browser*=*true*|\
    *web_search*=*enabled*|\
    *web_search*=*true*)
      return 0
      ;;
  esac
  return 1
}

prev=""
for arg in "$@"; do
  if [ "$prev" = "--enable" ]; then
    case "$arg" in
      browser_use|computer_use|in_app_browser)
        printf 'carc-codex: blocked unsafe Codex feature enable: %s\n' "$arg" >&2
        exit 2
        ;;
    esac
  fi
  if [ "$prev" = "-c" ] || [ "$prev" = "--config" ]; then
    if unsafe_config_override "$arg"; then
      printf 'carc-codex: blocked unsafe Codex config override: %s\n' "$arg" >&2
      exit 2
    fi
  fi
  case "$arg" in
    --dangerously-bypass-approvals-and-sandbox|--sandbox=danger-full-access|--ask-for-approval=never)
      printf 'carc-codex: blocked unsafe Codex option: %s\n' "$arg" >&2
      exit 2
      ;;
    --search)
      printf 'carc-codex: blocked live web search flag: %s\n' "$arg" >&2
      exit 2
      ;;
    --enable=browser_use|--enable=computer_use|--enable=in_app_browser)
      printf 'carc-codex: blocked unsafe Codex feature enable: %s\n' "$arg" >&2
      exit 2
      ;;
    --config=*|-c=*)
      value="${arg#*=}"
      if unsafe_config_override "$value"; then
        printf 'carc-codex: blocked unsafe Codex config override: %s\n' "$arg" >&2
        exit 2
      fi
      ;;
    danger-full-access|never)
      if [ "$prev" = "--sandbox" ] || [ "$prev" = "-s" ] || [ "$prev" = "--ask-for-approval" ] || [ "$prev" = "-a" ]; then
        printf 'carc-codex: blocked unsafe Codex option value: %s %s\n' "$prev" "$arg" >&2
        exit 2
      fi
      ;;
  esac
  prev="$arg"
done

exec "$REAL_CODEX" \
  --sandbox workspace-write \
  --ask-for-approval untrusted \
  --disable browser_use \
  --disable computer_use \
  --disable in_app_browser \
  --enable hooks \
  -c 'sandbox_workspace_write.network_access=false' \
  -c 'web_search="disabled"' \
  -c 'hooks.PreToolUse=[{ matcher = "^(Bash|apply_patch|Edit|Write|Read|MultiEdit|NotebookEdit)$", hooks = [{ type = "command", command = "$HOME/.codex/hooks/precheck.sh", timeout = 10, statusMessage = "Checking CARC policy" }] }]' \
  "$@"
